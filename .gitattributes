# Always use LF line endings for scripts
*.cs text eol=lf
*.sh text eol=lf
*.proto text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eof=lf
# Binary files should remain as-is
*.dll binary
*.pdb binary
*.exe binary
*.so binary
*.dylib binary
